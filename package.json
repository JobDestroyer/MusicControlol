{
  "name": "music-control",
  "version": "2.0.3",
  "description": "Control MPRIS media players (Strawberry, Spotify, Firefox) from Steam Deck Game Mode via Decky.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "python3 tests/test_metadata.py"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirobouma/MusicControl.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "music",
    "mpris",
    "strawberry",
    "steam-deck"
  ],
  "author": "MusicControl maintainers",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mirobouma/MusicControl/issues"
  },
  "homepage": "https://github.com/mirobouma/MusicControl#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
